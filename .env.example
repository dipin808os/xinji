# 复制这个文件为 .env 并填入你的 key，就能接上真正的大模型（DeepSeek）
# 没有 key 也能跑：后端会自动降级为内置的温暖模拟回应
DEEPSEEK_API_KEY=
LLM_MODEL=deepseek-chat
LLM_NAME=DeepSeek
# 如需第三方中转或换用其它 OpenAI 兼容服务，改这里（不带 /chat/completions）
# LLM_BASE_URL=https://api.deepseek.com
PORT=5178

# ── 部署相关（本地开发可留空）────────────────────────────
# 会话签名密钥。留空则自动生成并存到 data/session-secret。
SESSION_SECRET=
# HTTPS 部署时置 1，让登录 cookie 只在 https 下发送
COOKIE_SECURE=
# AI 接口每用户限频：AI_RATE_WINDOW 秒内最多 AI_RATE_MAX 次
AI_RATE_MAX=30
AI_RATE_WINDOW=60
